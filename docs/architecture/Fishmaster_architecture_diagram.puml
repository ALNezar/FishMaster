@startuml
!theme vibrant
skinparam componentStyle rectangle
skinparam NoteBackgroundColor #f9f9f9
skinparam linetype ortho

title Fishmaster Cloud Architecture\nPSM 2 — IoT Aquarium Monitoring (Railway Monolith)

' --- User ---
actor "User" as user

' --- Cloud Services ---
package "Cloud Services (Railway)" {
    component "React Dashboard" as react #LightGreen
    component "REST API" as rest
    component "Service Logic" as logic
    component "MQTT Listener" as listener
    database "PostgreSQL\n[tank_id, ts]" as db
    
    ' Internal Flow
    react ..> rest : REST Polling / POST
    rest --> logic
    logic -[#green]-> db : **persist**
    listener --> logic
}

package "MQTT Broker (HiveMQ)" {
    node "HiveMQ Cloud" as hivemq
    note right of hivemq
        **Topics** (QoS 1)
        FishMaster/{tankId}/sensor
        FishMaster/{tankId}/control
        FishMaster/{tankId}/alert
    end note
}

' --- Hardware Layer ---
package "Hardware Layer" {
    node "ESP32 (tank_1)" as esp
    component "Temp" as temp
    component "pH" as ph
    component "Turbidity" as turb

    esp -- temp
    esp -- ph
    esp -- turb
}

' --- Cross-Boundary Connections ---
user --> react : views dashboard\n& triggers actions

' 1. Sensor Data (Blue)
esp -[#blue]up-> hivemq : Publish Sensor Data
hivemq -[#blue]up-> listener : Subscribe Sensor Data
rest -[#blue]up-> react : Fetch Data

' 2. Control Flows (Red)
logic -[#red]down-> hivemq : Publish Command
hivemq -[#red]down-> esp : Subscribe Control

' --- Legend ---
note as Legend
    **Legend**
    <color:blue>■</color> Sensor Data Flow (Upwards)
    <color:red>■</color> Control Command Flow (Downwards)
    <color:green>■</color> Persistence

    **Deployment**
    - **Frontend:** Built into Spring Boot static resources
    - **Backend:** Spring Boot monolith on Railway
end note

@enduml
